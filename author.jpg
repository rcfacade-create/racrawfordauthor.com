:root {
  --bg: #0f1115;
  --panel: #171a21;
  --gold: #d4b06a;
  --text: #ece8df;
  --muted: #b7afa2;
  --blue: #5a6b87;
  --crimson: #8a1e2a;
  --shadow: rgba(0,0,0,.45);
}
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0;
  font-family: Lora, serif;
  color: var(--text);
  background: radial-gradient(circle at top left, rgba(212,176,106,.12), transparent 34%), var(--bg);
  line-height: 1.7;
}
a { color: inherit; }
.ambient { position: fixed; inset: 0; pointer-events: none; background-image: radial-gradient(circle at 20% 20%, rgba(212,176,106,.07), transparent 18%), radial-gradient(circle at 80% 30%, rgba(90,107,135,.10), transparent 22%); z-index: -1; }
.site-header { position: sticky; top: 0; z-index: 10; display:flex; justify-content:space-between; align-items:center; padding: 18px 6vw; background: rgba(15,17,21,.84); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(212,176,106,.18); }
.logo, h1, h2, h3 { font-family: Cinzel, serif; letter-spacing: .05em; }
.logo { text-decoration:none; color: var(--gold); font-weight: 900; }
.site-nav { display:flex; gap: 24px; font-family: Inter, sans-serif; font-size: .9rem; }
.site-nav a { text-decoration:none; color: var(--muted); }
.site-nav a:hover { color: var(--gold); }
.nav-toggle { display:none; background:none; color:var(--gold); border:0; font-size:1.6rem; }
.hero { min-height: 88vh; display:grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items:center; padding: 70px 6vw; }
.hero h1 { font-size: clamp(2.7rem, 6vw, 6.5rem); line-height: .95; margin: 10px 0 18px; }
.eyebrow { font-family: Inter, sans-serif; color: var(--gold); text-transform: uppercase; letter-spacing: .25em; font-weight: 700; font-size: .78rem; }
.tagline { font-size: 1.3rem; color: var(--gold); font-style: italic; }
.intro { max-width: 620px; color: var(--muted); }
.hero-image img, .portrait-card img { width:100%; border-radius: 22px; box-shadow: 0 30px 80px var(--shadow); border: 1px solid rgba(212,176,106,.25); }
.button-row { display:flex; flex-wrap:wrap; gap: 16px; margin-top: 28px; }
.button, button { font-family: Inter, sans-serif; text-decoration:none; padding: 13px 22px; border-radius: 999px; font-weight: 700; transition: .25s ease; border: 1px solid var(--gold); cursor:pointer; }
.button.primary, form button { background: var(--gold); color: #111; }
.button.secondary { color: var(--gold); background: transparent; }
.button:hover, form button:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(212,176,106,.18); }
.section { padding: 90px 6vw; }
.split { display:grid; grid-template-columns: .8fr 1.2fr; gap: 64px; align-items:center; }
.reverse { grid-template-columns: 1.2fr .8fr; }
.book-cover img { width:min(100%, 420px); display:block; margin:auto; border-radius: 12px; box-shadow: 0 30px 70px var(--shadow); transition: .35s ease; }
.book-cover img:hover { transform: perspective(900px) rotateY(-5deg) translateY(-6px); }
.section-copy h2, .world h2, .newsletter h2 { font-size: clamp(2rem, 4vw, 4rem); line-height:1.05; margin: 10px 0 20px; }
.section-copy p { color: var(--muted); max-width: 680px; }
.note, .small { font-size:.95rem; color: var(--muted); }
.world { text-align:center; background: linear-gradient(180deg, transparent, rgba(23,26,33,.72), transparent); }
.cards { display:grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 36px; }
.cards article { background: rgba(23,26,33,.88); padding: 30px; border: 1px solid rgba(212,176,106,.16); border-radius: 18px; box-shadow: 0 20px 55px rgba(0,0,0,.22); }
.cards h3 { color: var(--gold); }
.cards p { color: var(--muted); }
.newsletter { margin: 70px 6vw; padding: 60px; text-align:center; background: linear-gradient(135deg, rgba(138,30,42,.28), rgba(23,26,33,.95)); border: 1px solid rgba(212,176,106,.25); border-radius: 26px; }
form { display:flex; max-width: 560px; margin: 28px auto 10px; gap: 12px; }
input { flex:1; min-width:0; padding: 14px 18px; border-radius: 999px; border: 1px solid rgba(212,176,106,.35); background: rgba(255,255,255,.06); color: var(--text); }
footer { padding: 40px 6vw; text-align:center; color: var(--muted); border-top: 1px solid rgba(212,176,106,.14); }
.reveal { opacity:0; transform: translateY(18px); transition: .75s ease; }
.reveal.visible { opacity:1; transform: translateY(0); }
@media (max-width: 850px) {
  .nav-toggle { display:block; }
  .site-nav { display:none; position:absolute; top:64px; right:6vw; flex-direction:column; background: var(--panel); padding: 20px; border-radius:14px; border:1px solid rgba(212,176,106,.2); }
  .site-nav.open { display:flex; }
  .hero, .split, .reverse { grid-template-columns:1fr; }
  .hero { padding-top: 44px; }
  .cards { grid-template-columns:1fr; }
  form { flex-direction:column; }
  .newsletter { margin: 40px 4vw; padding: 34px 22px; }
}
