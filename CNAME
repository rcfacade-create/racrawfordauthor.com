*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:radial-gradient(circle at top,#17130d 0,#050505 42%,#010101 100%);color:var(--text);font-family:Georgia,'Times New Roman',serif;line-height:1.65;overflow-x:hidden}a{color:inherit;text-decoration:none}img{max-width:100%;display:block}.site-header{position:sticky;top:0;z-index:50;background:rgba(0,0,0,.86);backdrop-filter:blur(8px);border-bottom:1px solid var(--line)}.nav{max-width:1240px;margin:0 auto;padding:16px 22px;display:flex;align-items:center;justify-content:space-between;gap:20px}.brand{display:flex;flex-direction:column;line-height:1}.brand strong{font-size:1.35rem;letter-spacing:.12em;color:var(--gold2);text-transform:uppercase}.brand span{font-size:.72rem;letter-spacing:.22em;color:var(--muted);text-transform:uppercase}.links{display:flex;gap:26px;align-items:center;text-transform:uppercase;font-size:.8rem;letter-spacing:.16em}.links a{color:var(--text);opacity:.9}.links a:hover,.links a.active{color:var(--gold2)}.menu-btn{display:none;background:transparent;border:1px solid var(--line);color:var(--gold2);padding:8px 10px;font-size:1rem}.hero{min-height:88vh;position:relative;display:grid;place-items:center;text-align:center;padding:120px 22px 80px;overflow:hidden;border-bottom:1px solid var(--line)}.hero:before{content:"";position:absolute;inset:0;background:linear-gradient(rgba(0,0,0,.45),rgba(0,0,0,.82)),url('assets/cover.jpg') center 20%/cover no-repeat;filter:brightness(.65) saturate(.8);transform:scale(1.05);z-index:-2}.hero:after{content:"";position:absolute;inset:0;background:radial-gradient(circle at center,rgba(216,180,106,.08),transparent 45%),linear-gradient(90deg,rgba(0,0,0,.8),transparent 35%,rgba(0,0,0,.65));z-index:-1}.hero-inner{max-width:900px}.kicker{letter-spacing:.28em;text-transform:uppercase;color:var(--gold);font-size:.9rem;margin-bottom:12px}.hero h1{font-size:clamp(3rem,9vw,8rem);line-height:.88;margin:0;text-transform:uppercase;letter-spacing:.04em;color:#f7e8c7;text-shadow:0 0 20px #000,0 0 35px rgba(216,180,106,.22)}.subtitle{margin:28px auto 10px;color:var(--gold);letter-spacing:.22em;text-transform:uppercase;font-size:1rem}.tagline{max-width:720px;margin:22px auto 34px;font-size:clamp(1.05rem,2vw,1.35rem);color:#f2eadb}.btn-row{display:flex;justify-content:center;gap:16px;flex-wrap:wrap}.btn{display:inline-block;border:1px solid var(--line);padding:13px 24px;color:var(--gold2);letter-spacing:.14em;text-transform:uppercase;background:rgba(0,0,0,.35);transition:.2s}.btn:hover{background:rgba(216,180,106,.13);transform:translateY(-2px)}.btn.primary{background:linear-gradient(180deg,#d8b46a,#9c7432);color:#111;font-weight:bold}.section{max-width:1180px;margin:0 auto;padding:78px 22px}.section-title{text-align:center;margin-bottom:42px}.section-title small{color:var(--gold);letter-spacing:.24em;text-transform:uppercase}.section-title h2{margin:8px 0 0;font-size:clamp(2rem,4vw,3.6rem);letter-spacing:.14em;text-transform:uppercase;color:#f0d89a}.ornate{height:1px;background:linear-gradient(90deg,transparent,var(--line),transparent);margin:24px auto;max-width:700px}.grid-2{display:grid;grid-template-columns:0.9fr 1.1fr;gap:48px;align-items:center}.card{background:linear-gradient(180deg,rgba(255,255,255,.03),rgba(255,255,255,.01));border:1px solid var(--line);box-shadow:0 30px 90px rgba(0,0,0,.5);padding:28px}.book-cover{max-width:330px;margin:auto;border:1px solid var(--line);box-shadow:0 22px 60px #000}.portrait{max-width:360px;border:1px solid var(--line);box-shadow:0 25px 70px #000}.map-frame{border:1px solid var(--line);background:#0c0905;padding:12px;box-shadow:0 25px 80px #000}.map-frame img{width:100%;height:auto}.features{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}.feature{border:1px solid var(--line);padding:28px;text-align:center;background:rgba(0,0,0,.28)}.feature h3{color:var(--gold2);letter-spacing:.12em;text-transform:uppercase}.quote{font-style:italic;color:#f0d89a;font-size:1.35rem;text-align:center;margin:34px 0}.page-hero{padding:90px 22px 55px;text-align:center;background:linear-gradient(rgba(0,0,0,.8),rgba(0,0,0,.9)),url('assets/cover.jpg') center/cover no-repeat;border-bottom:1px solid var(--line)}.page-hero h1{font-size:clamp(2.4rem,6vw,5rem);text-transform:uppercase;letter-spacing:.16em;color:var(--gold2);margin:0}.footer{border-top:1px solid var(--line);text-align:center;padding:34px 22px;color:var(--muted);background:#030303}.feather{position:fixed;top:-80px;z-index:20;pointer-events:none;width:18px;height:46px;opacity:.78;border-radius:60% 40% 60% 40%;background:linear-gradient(90deg,transparent 0 45%,rgba(255,255,255,.9) 48% 52%,transparent 55%),linear-gradient(135deg,rgba(255,255,255,.95),rgba(216,180,106,.25) 55%,rgba(20,20,20,.35));filter:drop-shadow(0 0 6px rgba(255,255,255,.15));animation:fall linear forwards}.feather:before,.feather:after{content:"";position:absolute;left:50%;top:6px;width:1px;height:36px;background:rgba(90,70,45,.45);transform:translateX(-50%)}.feather:after{width:14px;height:24px;background:transparent;border-left:1px solid rgba(80,60,40,.28);border-radius:50%;transform:translateX(-50%) rotate(28deg)}@keyframes fall{0%{transform:translateY(-90px) translateX(0) rotate(0deg)}45%{transform:translateY(50vh) translateX(65px) rotate(135deg)}100%{transform:translateY(110vh) translateX(-45px) rotate(300deg)}}@media(max-width:800px){.links{display:none;position:absolute;left:0;right:0;top:66px;background:#050505;border-bottom:1px solid var(--line);padding:18px;flex-direction:column}.links.open{display:flex}.menu-btn{display:block}.grid-2{grid-template-columns:1fr}.features{grid-template-columns:1fr}.hero h1{font-size:3rem}.section{padding:56px 18px}.portrait{max-width:280px;margin:auto}}
